# Example environment variables for Healthcare Virtual Assistant
# Development: NODE_ENV=development | Production: NODE_ENV=production
NODE_ENV=development
PORT=${PORT:-5000}

# JWT Secret (REQUIRED for production - use a strong random string)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production

# Storage provider (firebase|memory)
STORAGE_PROVIDER=memory

# Firebase Configuration (Optional - for Firestore)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email Configuration (Optional - for notifications)
SMTP_API_KEY=
CONTACT_EMAIL=support@healthcareapp.com

# Application URL (for emails, redirects)
APP_URL=http://localhost:5000
