{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Backend (Node)",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/server.js",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Start Expo (npm)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
